{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".", // 基于项目根目录
    "paths": {
      "@/*": ["./src/*"] // TS 识别 @ 指向 src
    }
  }
}